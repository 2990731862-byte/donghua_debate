.debater-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.debater-info {
  flex: 1;
}

.debater-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.debater-name-row {
  display: flex;
  align-items: baseline;
}

.debater-student-id {
  font-size: 22rpx;
  color: #999999;
  margin-left: 12rpx;
}

.debater-meta {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.debater-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.edit-btn {
  background: #E8F4FD;
  color: #1890FF;
}

.delete-btn {
  background: #FFF1F0;
  color: #F5222D;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.2s ease;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  padding: 40rpx;
  animation: scaleIn 0.2s ease;
}

@keyframes scaleIn {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  text-align: center;
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.form-input {
  background: #F6F6F6;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.form-buttons .btn-secondary,
.form-buttons .btn-primary {
  flex: 1;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx;
}

.debater-list {
  padding-bottom: env(safe-area-inset-bottom);
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

/* 顶部按钮栏 */
.top-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.add-btn {
  flex: 1;
}

.college-btn {
  padding: 20rpx 28rpx;
}

/* Picker */
.picker-input {
  display: flex;
  align-items: center;
}

/* 学院管理弹窗 */
.college-add-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.college-add-input {
  flex: 1;
}

.college-add-btn {
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

.college-list-scroll {
  max-height: 500rpx;
}

.college-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.college-item:last-child {
  border-bottom: none;
}

.college-name {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.college-del {
  font-size: 24rpx;
  color: #F5222D;
  padding: 8rpx 16rpx;
}

.college-empty {
  padding: 60rpx 0;
  text-align: center;
}



.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 12rpx;
}

.hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.generate-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.generate-row .section-title {
  margin-bottom: 0;
}

.generate-btn {
  font-size: 24rpx;
  padding: 10rpx 28rpx;
}

.code-list {
  margin-top: 8rpx;
}

.code-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.code-item:last-child {
  border-bottom: none;
}

.code-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.code-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  letter-spacing: 4rpx;
}

.code-text.used,
.code-text.expired {
  color: #CCCCCC;
}

.code-status {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.code-status.active {
  background: #F6FFED;
  color: #52C41A;
}

.code-status.used {
  background: #F0F0F0;
  color: #999999;
}

.code-status.expired {
  background: #FFF1F0;
  color: #F5222D;
}

.code-date {
  display: block;
  font-size: 22rpx;
  color: #BBBBBB;
  margin-top: 8rpx;
}

.code-user {
  display: block;
  font-size: 22rpx;
  color: #1890FF;
  margin-top: 6rpx;
}

.code-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
}

.copy-action {
  background: #F0F5FF;
  color: #1890FF;
}

.delete-action {
  background: #FFF1F0;
  color: #F5222D;
}

.empty-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #CCCCCC;
}

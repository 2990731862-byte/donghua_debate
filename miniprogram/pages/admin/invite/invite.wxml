<view class="container">
  <!-- 生成邀请码 -->
  <view class="card fade-in">
    <view class="generate-row">
      <text class="section-title">生成邀请码</text>
      <view class="btn-primary generate-btn" bindtap="generateCode">生成新邀请码</view>
    </view>
    <text class="hint">每个邀请码有效期为7天，被使用后自动失效</text>
  </view>

  <!-- 邀请码列表 -->
  <view class="card fade-in" style="animation-delay: 0.1s" wx:if="{{codes.length > 0}}">
    <text class="section-title">邀请码记录</text>

    <view class="code-list">
      <view class="code-item" wx:for="{{codes}}" wx:key="_id">
        <view class="code-main">
          <text class="code-text {{item.statusClass}}">{{item.code}}</text>
          <text class="code-status {{item.statusClass}}">{{item.status}}</text>
        </view>
        <text class="code-date">有效期至：{{item.expiresAtStr}}</text>
        <text class="code-user" wx:if="{{item.used && item.usedByName}}">使用者：{{item.usedByName}}</text>
        <view class="code-actions">
          <view class="action-btn copy-action" bindtap="copyCode" data-code="{{item.code}}">
            <text>复制</text>
          </view>
          <view class="action-btn delete-action" bindtap="deleteCode" data-id="{{item._id}}" data-code="{{item.code}}" data-status="{{item.status}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{codes.length === 0}}">
    <text class="empty-text">暂无邀请码记录</text>
  </view>
</view>

<view class="container" wx:if="{{authorized}}">
  <!-- 欢迎 -->
  <view class="card welcome-card fade-in">
    <text class="welcome-title">管理面板</text>
    <text class="welcome-role">{{role === 'super_admin' ? '超级管理员' : '管理员'}}</text>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row fade-in" style="animation-delay: 0.1s">
    <view class="stat-card card">
      <text class="stat-num">{{stats.debaterCount}}</text>
      <text class="stat-label">辩手</text>
    </view>
    <view class="stat-card card">
      <text class="stat-num">{{stats.matchCount}}</text>
      <text class="stat-label">比赛</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions fade-in" style="animation-delay: 0.15s">
    <view class="action-card card" bindtap="goMatchForm">
      <text class="action-icon">📝</text>
      <view class="action-info">
        <text class="action-title">录入比赛</text>
        <text class="action-desc">录入新的比赛结果</text>
      </view>
      <text class="action-arrow">›</text>
    </view>

    <view class="action-card card" bindtap="goDebaterManage">
      <text class="action-icon">👥</text>
      <view class="action-info">
        <text class="action-title">管理辩手</text>
        <text class="action-desc">添加、编辑辩手信息</text>
      </view>
      <text class="action-arrow">›</text>
    </view>

    <view class="action-card card" bindtap="goInvite" wx:if="{{role === 'super_admin'}}">
      <text class="action-icon">🔑</text>
      <view class="action-info">
        <text class="action-title">邀请管理</text>
        <text class="action-desc">生成邀请码</text>
      </view>
      <text class="action-arrow">›</text>
    </view>

    <view class="action-card card" bindtap="recalculate">
      <text class="action-icon">🔄</text>
      <view class="action-info">
        <text class="action-title">重算积分</text>
        <text class="action-desc">全量重新计算所有积分</text>
      </view>
      <text class="action-arrow">›</text>
    </view>
  </view>
</view>

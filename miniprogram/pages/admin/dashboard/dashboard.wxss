.welcome-card {
  text-align: center;
  padding: 40rpx;
}

.welcome-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.welcome-role {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 28rpx 16rpx;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

/* 清空数据提示卡片 */
.clear-info-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.clear-info-label {
  font-size: 24rpx;
  color: #999999;
  flex: 1;
}

.clear-info-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.clear-info-date.overdue {
  color: #E94560;
}

.clear-info-hint {
  width: 100%;
  font-size: 22rpx;
  color: #E94560;
  margin-top: 4rpx;
}

.action-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  transition: transform 0.2s ease;
}

.action-card:active {
  transform: scale(0.98);
}

.action-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.action-info {
  flex: 1;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.action-desc {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* 危险操作样式 */
.danger-card {
  border-left: 6rpx solid #E94560;
}

.danger-title {
  color: #E94560;
}

.danger-desc {
  color: #E94560;
}

.welcome-card {
  text-align: center;
  padding: 40rpx;
}

.welcome-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.welcome-role {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 28rpx 16rpx;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.action-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  transition: transform 0.2s ease;
}

.action-card:active {
  transform: scale(0.98);
}

.action-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.action-info {
  flex: 1;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.action-desc {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

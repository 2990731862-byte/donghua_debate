<view class="container">
  <!-- 步骤指示器 -->
  <view class="steps-bar">
    <view class="step {{step >= 1 ? 'active' : ''}}">
      <view class="step-dot">1</view>
      <text class="step-label">比赛信息</text>
    </view>
    <view class="step-line {{step >= 2 ? 'active' : ''}}"></view>
    <view class="step {{step >= 2 ? 'active' : ''}}">
      <view class="step-dot">2</view>
      <text class="step-label">选参赛者</text>
    </view>
    <view class="step-line {{step >= 3 ? 'active' : ''}}"></view>
    <view class="step {{step >= 3 ? 'active' : ''}}">
      <view class="step-dot">3</view>
      <text class="step-label">详细信息</text>
    </view>
    <view class="step-line {{step >= 4 ? 'active' : ''}}"></view>
    <view class="step {{step >= 4 ? 'active' : ''}}">
      <view class="step-dot">4</view>
      <text class="step-label">确认提交</text>
    </view>
  </view>

  <!-- 步骤1：比赛基本信息 -->
  <view class="step-content card" wx:if="{{step === 1}}">
    <text class="step-title">比赛基本信息</text>

    <view class="form-group">
      <text class="form-label">比赛名称</text>
      <view class="name-input-wrap">
        <input class="form-input" placeholder="年份+赛事（例如2026镜月杯）" value="{{matchName}}" bindinput="onMatchNameInput" bindfocus="onMatchNameFocus" bindblur="onMatchNameBlur" />
        <view class="name-suggestions" wx:if="{{showNameSuggestions}}" catchtouchmove="preventTouchMove">
          <scroll-view scroll-y class="name-suggestion-scroll" enhanced show-scrollbar="{{false}}">
            <view
              class="name-suggestion-item"
              wx:for="{{matchNameSuggestions}}"
              wx:key="*this"
              catchtap="selectMatchName"
              data-name="{{item}}"
            >
              <text>{{item}}</text>
            </view>
          </scroll-view>
        </view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">赛事级别</text>
      <view class="level-picker">
        <view
          class="level-option {{matchLevel === '院赛' ? 'active' : ''}}"
          bindtap="onLevelChange"
          data-level="院赛"
        >
          <text>院赛 (W=1)</text>
        </view>
        <view
          class="level-option {{matchLevel === '校赛' ? 'active' : ''}}"
          bindtap="onLevelChange"
          data-level="校赛"
        >
          <text>校赛 (W=2)</text>
        </view>
        <view
          class="level-option {{matchLevel === '市赛' ? 'active' : ''}}"
          bindtap="onLevelChange"
          data-level="市赛"
        >
          <text>市赛 (W=4)</text>
        </view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">比赛日期</text>
      <picker mode="date" value="{{matchDate}}" end="{{maxDate}}" bindchange="onDateChange">
        <view class="form-input picker-input">
          <text>{{matchDate || '请选择日期'}}</text>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">赛程</text>
      <view class="stage-picker">
        <view class="level-option {{matchStage === '初赛' ? 'active' : ''}}" bindtap="onStageChange" data-stage="初赛">
          <text>初赛</text>
        </view>
        <view class="level-option {{matchStage === '小组赛' ? 'active' : ''}}" bindtap="onStageChange" data-stage="小组赛">
          <text>小组赛</text>
        </view>
        <view class="level-option {{matchStage === '复赛' ? 'active' : ''}}" bindtap="onStageChange" data-stage="复赛">
          <text>复赛</text>
        </view>
        <view class="level-option {{matchStage === '半决赛' ? 'active' : ''}}" bindtap="onStageChange" data-stage="半决赛">
          <text>半决赛</text>
        </view>
        <view class="level-option {{matchStage === '决赛' ? 'active' : ''}}" bindtap="onStageChange" data-stage="决赛">
          <text>决赛</text>
        </view>
        <view class="level-option {{matchStage === '复活赛' ? 'active' : ''}}" bindtap="onStageChange" data-stage="复活赛">
          <text>复活赛</text>
        </view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">轮次</text>
      <view class="round-picker">
        <view
          class="round-option {{matchRound === item ? 'active' : ''}}"
          wx:for="{{[1,2,3,4,5]}}"
          wx:key="*this"
          bindtap="onRoundChange"
          data-round="{{item}}"
        >
          <text>第{{item}}轮</text>
        </view>
      </view>
    </view>

    <view class="step-buttons">
      <view class="btn-primary" bindtap="nextStep">下一步</view>
    </view>
  </view>

  <!-- 步骤2：选择参赛者 -->
  <view class="step-content" wx:if="{{step === 2}}">
    <text class="step-title">选择参赛辩手</text>

    <!-- 搜索栏 -->
    <view class="search-bar-wrap">
      <view class="search-bar-inner">
        <text class="search-icon-text">🔍</text>
        <input class="search-input-box" placeholder="搜索辩手姓名或学院" value="{{searchKeyword}}" bindinput="onSearchInput" />
        <text class="search-clear-btn" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
      </view>
    </view>

    <!-- 已选计数 -->
    <view class="selected-count-bar" wx:if="{{selectedCount > 0}}">
      <text>已选 {{selectedCount}} 人</text>
    </view>

    <!-- 辩手列表（分组滚动） -->
    <scroll-view scroll-y class="debater-scroll-view" enhanced show-scrollbar="{{false}}">
      <view wx:for="{{groupedDebaters}}" wx:key="letter">
        <view class="letter-section-title" id="letter-{{item.letter}}">{{item.letter}}</view>
        <view
          class="debater-select-item {{debater.selected ? 'selected' : ''}}"
          wx:for="{{item.items}}"
          wx:for-item="debater"
          wx:key="_id"
          bindtap="toggleDebater"
          data-id="{{debater._id}}"
        >
          <view class="select-check">{{debater.selected ? '✓' : ''}}</view>
          <text class="select-name">{{debater.name}}</text>
          <text class="select-student-id" wx:if="{{debater.studentId}}">{{debater.studentId}}</text>
          <text class="select-college">{{debater.college}}</text>
        </view>
      </view>
      <view class="empty-search" wx:if="{{filteredDebaters.length === 0 && searchKeyword}}">
        <text>未找到匹配的辩手</text>
      </view>
      <view style="height: 40rpx;"></view>
    </scroll-view>

    <!-- 字母索引 -->
    <view class="letter-sidebar" wx:if="{{groupedDebaters.length > 0 && !searchKeyword}}">
      <text
        class="letter-sidebar-item {{item === groupedDebaters[0].letter ? 'active' : ''}}"
        wx:for="{{letters}}"
        wx:key="*this"
        bindtap="onLetterTap"
        data-letter="{{item}}"
      >{{item}}</text>
    </view>

    <view class="step-buttons" style="margin-top: 16rpx;">
      <view class="btn-secondary" bindtap="prevStep">上一步</view>
      <view class="btn-primary" bindtap="nextStep">下一步</view>
    </view>
  </view>

  <!-- 步骤3：每位参赛者的详细信息 -->
  <view class="step-content" wx:if="{{step === 3}}">
    <text class="step-title" style="margin-bottom: 16rpx;">参赛者详情</text>

    <view class="participant-card card" wx:for="{{participants}}" wx:key="debaterId">
      <view class="participant-name-row">
        <text class="participant-name">{{item.debaterName}}</text>
        <text class="participant-student-id" wx:if="{{item.studentId}}">{{item.studentId}}</text>
      </view>

      <view class="form-group">
        <view class="checkbox-row" bindtap="toggleBestDebater" data-pindex="{{index}}">
          <view class="checkbox {{item.isBestDebater ? 'checked' : ''}}">
            <text wx:if="{{item.isBestDebater}}">✓</text>
          </view>
          <text class="checkbox-label">最佳辩手</text>
        </view>
      </view>

      <view class="form-group">
        <view class="checkbox-row" bindtap="toggleTopThree" data-pindex="{{index}}">
          <view class="checkbox {{item.topThreeFinish ? 'checked' : ''}}">
            <text wx:if="{{item.topThreeFinish}}">✓</text>
          </view>
          <text class="checkbox-label">获得前三名（冠亚季军）</text>
        </view>
      </view>
    </view>

    <view class="step-buttons">
      <view class="btn-secondary" bindtap="prevStep">上一步</view>
      <view class="btn-primary" bindtap="nextStep">下一步</view>
    </view>
  </view>

  <!-- 步骤4：确认提交 -->
  <view class="step-content card" wx:if="{{step === 4}}">
    <text class="step-title">确认比赛信息</text>

    <view class="confirm-section">
      <view class="confirm-row">
        <text class="confirm-label">比赛名称</text>
        <text class="confirm-value">{{matchName}}</text>
      </view>
      <view class="confirm-row">
        <text class="confirm-label">赛事级别</text>
        <text class="confirm-value">{{matchLevel}} (W={{matchWeight}})</text>
      </view>
      <view class="confirm-row">
        <text class="confirm-label">比赛日期</text>
        <text class="confirm-value">{{matchDate}}</text>
      </view>
      <view class="confirm-row">
        <text class="confirm-label">赛程</text>
        <text class="confirm-value">{{matchStage}}</text>
      </view>
      <view class="confirm-row">
        <text class="confirm-label">轮次</text>
        <text class="confirm-value">第{{matchRound}}轮</text>
      </view>
      <view class="confirm-row">
        <text class="confirm-label">参赛人数</text>
        <text class="confirm-value">{{participants.length}}人</text>
      </view>
    </view>

    <view class="confirm-participants">
      <text class="form-label">参赛者详情</text>
      <view class="confirm-participant" wx:for="{{participants}}" wx:key="debaterId">
        <view class="cp-name-row">
          <text class="cp-name">{{item.debaterName}}</text>
          <text class="cp-student-id" wx:if="{{item.studentId}}">{{item.studentId}}</text>
        </view>
        <text class="cp-detail" wx:if="{{item.isBestDebater}}">佳辩</text>
        <text class="cp-detail cp-top3" wx:if="{{item.topThreeFinish}}">🏆 前三名</text>
      </view>
    </view>

    <view class="step-buttons">
      <view class="btn-secondary" bindtap="prevStep">上一步</view>
      <view class="btn-primary submit-btn" bindtap="submitMatch">确认提交</view>
    </view>
  </view>
</view>

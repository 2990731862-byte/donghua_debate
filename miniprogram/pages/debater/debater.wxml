<view class="container" wx:if="{{!loading}}">
  <!-- 头部信息 -->
  <view class="profile-card card fade-in">
    <view class="profile-rank" wx:if="{{debater.rank <= 3}}">
      <text class="rank-badge">{{debater.rank === 1 ? '🥇' : debater.rank === 2 ? '🥈' : '🥉'}}</text>
    </view>
    <view class="profile-rank" wx:else>
      <text class="rank-num">#{{debater.rank}}</text>
    </view>

    <view class="profile-info">
      <text class="profile-name">{{debater.name}}</text>
      <view class="profile-meta">
        <text class="profile-college">{{debater.college}}</text>
        <text class="profile-grade">{{debater.grade}}级</text>
      </view>
    </view>

    <view class="profile-score">
      <text class="score-big">{{debater.totalScore}}</text>
      <text class="score-unit">积分</text>
    </view>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row fade-in" style="animation-delay: 0.1s">
    <view class="stat-item card">
      <text class="stat-value">{{debater.matchCount}}</text>
      <text class="stat-label">比赛场次</text>
    </view>
    <view class="stat-item card">
      <text class="stat-value">{{personalRecordsSummary.maxRound}}</text>
      <text class="stat-label">最高轮次</text>
    </view>
    <view class="stat-item card">
      <text class="stat-value">{{personalRecordsSummary.bestDebaterCount}}</text>
      <text class="stat-label">最佳辩手</text>
    </view>
  </view>

  <!-- 个人纪录 -->
  <view class="card fade-in" style="animation-delay: 0.15s">
    <text class="section-title">个人纪录</text>
    <view class="records-grid">
      <view class="record-item" wx:for="{{recordsList}}" wx:key="level">
        <text class="tag {{item.level === '院赛' ? 'tag-college' : item.level === '校赛' ? 'tag-school' : 'tag-city'}}">{{item.level}}</text>
        <text class="record-detail">最高第{{item.maxRound}}轮</text>
        <text class="record-extra" wx:if="{{item.bestDebater}}">🏅 佳辩</text>
        <text class="record-extra" wx:if="{{item.topThree}}">🏆 前三</text>
      </view>
      <view class="empty-records" wx:if="{{recordsList.length === 0}}">
        <text class="text-secondary">暂无纪录</text>
      </view>
    </view>
  </view>

  <!-- 比赛历史 -->
  <view class="fade-in" style="animation-delay: 0.2s">
    <text class="section-title" style="margin-top: 8rpx;">比赛历史</text>
    <match-card
      wx:for="{{matches}}"
      wx:key="_id"
      match="{{item}}"
      participantScore="{{item.participantScore}}"
      index="{{index}}"
    />
    <view class="empty-state" wx:if="{{matches.length === 0}}">
      <text class="empty-text">暂无比赛记录</text>
    </view>
  </view>
</view>

<!-- 加载中 -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

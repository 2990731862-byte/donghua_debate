.profile-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.profile-rank {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-badge {
  font-size: 52rpx;
}

.rank-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #999999;
}

.profile-info {
  flex: 1;
  margin-left: 20rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.profile-name-row {
  display: flex;
  align-items: baseline;
}

.profile-student-id {
  font-size: 24rpx;
  color: #999999;
  margin-left: 12rpx;
}

.profile-meta {
  margin-top: 8rpx;
}

.profile-college {
  font-size: 24rpx;
  color: #999999;
  margin-right: 16rpx;
}

.profile-grade {
  font-size: 24rpx;
  color: #BBBBBB;
}

.profile-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.score-big {
  font-size: 48rpx;
  font-weight: 700;
  color: #E94560;
}

.score-unit {
  font-size: 22rpx;
  color: #999999;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 4rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 16rpx;
  display: block;
}

.records-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  min-width: 80rpx;
  text-align: center;
}

.tag-college {
  background: #E8F4FD;
  color: #1890FF;
}

.tag-school {
  background: #FFF7E6;
  color: #FA8C16;
}

.tag-city {
  background: #FFF1F0;
  color: #F5222D;
}

.record-detail {
  font-size: 26rpx;
  color: #666666;
}

.record-extra {
  font-size: 22rpx;
  color: #999999;
}

.empty-records {
  padding: 16rpx 0;
}

.match-history {
  padding-bottom: env(safe-area-inset-bottom);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F0F0F0;
  border-top: 4rpx solid #1A1A2E;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.empty-state {
  text-align: center;
  padding: 40rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

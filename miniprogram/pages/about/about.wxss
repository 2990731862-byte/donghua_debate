.header-card {
  text-align: center;
  position: relative;
  padding: 48rpx 24rpx;
}

.app-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.app-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.admin-entry {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.5;
}

.admin-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 20rpx;
  display: block;
}

.rule-section {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.rule-section:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.rule-subtitle {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
}

.rule-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.weight-table {
  margin-top: 8rpx;
}

.weight-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.weight-label {
  width: 100rpx;
  text-align: center;
}

.weight-value {
  margin-left: 24rpx;
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-college {
  background: #E8F4FD;
  color: #1890FF;
}

.tag-school {
  background: #FFF7E6;
  color: #FA8C16;
}

.tag-city {
  background: #FFF1F0;
  color: #F5222D;
}

.score-table {
  margin-top: 12rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.table-header {
  display: flex;
  background: #F8F8F8;
  padding: 12rpx 0;
}

.table-header .table-cell {
  font-weight: 600;
  color: #333333;
}

.table-row {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.table-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #666666;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: #CCCCCC;
  line-height: 1.8;
}
